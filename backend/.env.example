# ─────────────────────────────────────────────────────────────
#  LLM Configuration
#  The backend talks to any OpenAI-compatible /chat/completions
#  endpoint (OpenAI, Azure OpenAI, OpenRouter, Together, Groq,
#  vLLM, Ollama, LM Studio, local proxies, etc.).
# ─────────────────────────────────────────────────────────────

# Chat-completions endpoint. You can give either the full URL or just the
# base URL — the server appends /chat/completions when it's missing.
#   e.g. http://host/api/v1   ==   http://host/api/v1/chat/completions
# Examples:
#   OpenAI       -> https://api.openai.com/v1/chat/completions
#   OpenRouter   -> https://openrouter.ai/api/v1/chat/completions
#   Groq         -> https://api.groq.com/openai/v1/chat/completions
#   Ollama       -> http://localhost:11434/v1/chat/completions
#   LM Studio    -> http://localhost:1234/v1/chat/completions
LLM_ENDPOINT=https://api.openai.com/v1/chat/completions

# Model identifier understood by the endpoint above.
#   e.g. gpt-4o-mini, llama-3.3-70b-versatile, anthropic/claude-opus-4-8
LLM_MODEL=gpt-4o-mini

# API wire format: auto | openai | anthropic
#   auto      -> infer from the endpoint/model (default)
#   openai    -> POST {endpoint}/chat/completions, Bearer auth
#   anthropic -> POST {endpoint}/messages, x-api-key + anthropic-version
LLM_API_STYLE=auto

# API key / bearer token for the endpoint.
# Leave blank for local servers (Ollama / LM Studio) that need no auth.
LLM_API_KEY=sk-your-key-here

# ─────────────────────────────────────────────────────────────
#  Server Configuration (optional)
# ─────────────────────────────────────────────────────────────
PORT=4000

# Generation controls
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096

# ─────────────────────────────────────────────────────────────
#  Retrieval — Embeddings (optional, enables hybrid RAG)
#  When an embedding endpoint is reachable, retrieval blends BM25 with
#  semantic cosine similarity. If it's unreachable, retrieval transparently
#  falls back to pure BM25 — nothing else is required for the app to work.
# ─────────────────────────────────────────────────────────────

# Embedding endpoint. Defaults to a local Ollama server. Uses the
# OpenAI-style /v1/embeddings shape, falling back to Ollama's /api/embeddings.
#   Ollama  -> http://localhost:11434   (model: nomic-embed-text)
#   OpenAI  -> https://api.openai.com    (model: text-embedding-3-small)
EMBEDDINGS_URL=http://localhost:11434
EMBEDDINGS_MODEL=nomic-embed-text

# Hybrid blend weights (need not sum to 1; they're normalized).
RAG_WEIGHT_BM25=0.6
RAG_WEIGHT_SEM=0.4

# Max passages embedded per query (above this, only top BM25 candidates).
RAG_EMBED_POOL_MAX=256

# ─────────────────────────────────────────────────────────────
#  Retrieval — Corrective RAG (CRAG)
#  Grades retrieved passages for relevance and, when support is weak,
#  rewrites the query and re-retrieves before answering. Adds 1–2 small LLM
#  calls per /api/ask request. Set CRAG_ENABLED=false to disable.
# ─────────────────────────────────────────────────────────────
CRAG_ENABLED=true
CRAG_MAX_REWRITES=1
CRAG_RELEVANCE_THRESHOLD=0.5
CRAG_UPPER=0.7
CRAG_LOWER=0.3
CRAG_GRADE_CLIP=500
