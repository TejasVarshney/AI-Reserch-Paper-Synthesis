# Frontend env. Copy this to .env.local for local development.
# In production (Netlify), set the same vars in the Netlify UI:
#   Site settings → Environment variables → Add a variable
#
# VITE_API_URL must end without a trailing slash.
#   - Local dev: leave empty so the Vite dev server's /api proxy is used.
#   - Production: full URL of the deployed backend (e.g. https://synthesis-api.onrender.com)

VITE_API_URL=